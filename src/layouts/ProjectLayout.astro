---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  summary: string;
  role: string;
  technologies: string[];
  dateRange?: string;
}

const { title, summary, role, technologies, dateRange } = Astro.props;
---

<BaseLayout title={title} description={summary}>
  <p><a href="/projects">&larr; All projects</a></p>
  <h1>{title}</h1>
  <p class="meta">{role}{dateRange && ` · ${dateRange}`}</p>
  <ul class="tech-list">
    {technologies.map((tech) => <li>{tech}</li>)}
  </ul>
  <article>
    <slot />
  </article>
</BaseLayout>

<style>
  .meta {
    color: var(--color-muted);
  }

  .tech-list {
    list-style: none;
    margin: var(--spacing-2) 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-list li {
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    padding: 0.15rem 0.6rem;
    font-size: 0.85rem;
  }
</style>
