---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/paths';

const workStages = [
  {
    title: 'Learn',
    description:
      'Read the documentation, understand an unfamiliar system, and identify how it fits the project requirements.',
  },
  {
    title: 'Integrate',
    description:
      'Connect the technology to existing APIs, data, services, applications, or hardware without adding unnecessary complexity.',
  },
  {
    title: 'Deliver',
    description:
      'Make the implementation reliable enough for production, then support it through deployment and maintenance.',
  },
];

const careerChapters = [
  {
    period: '2018–2021',
    title: 'Enterprise software',
    description:
      'I developed software for government agencies, public organisations, and private-sector clients. The work ranged from database-driven web applications to Windows software, internal information systems, kiosks, and specialised hardware integration.',
  },
  {
    period: '2021–2026',
    title: 'Live-service games',
    description:
      'The industry changed, but the engineering pattern remained familiar. I worked on backend APIs, shared player services, multiplayer platforms, payments, communication services, and production deployments for browser and mobile games.',
  },
];

const selectedWork = [
  {
    domain: 'Live-service games',
    title: 'Tiny Little Platform',
    description: 'Shared backend services supporting seven commercial games across browser and mobile releases.',
    href: `${withBase('projects/')}#tiny-little-platform`,
  },
  {
    domain: 'Desktop software',
    title: 'RentPilot',
    description: 'An offline Windows dormitory management application deployed for an active client.',
    href: `${withBase('projects/')}#rentpilot`,
  },
];

const principles = [
  'Maintainable enough for another developer to understand.',
  'Reliable under the conditions where it will actually run.',
  'Simple enough to change when project requirements move.',
  'Appropriate for the problem rather than the current trend.',
];

const resumeHref = withBase('resume');
const projectsHref = withBase('projects/');
---

<BaseLayout
  title="Backend Developer"
  description="Veerakran Sereerungruangkul is a Backend Developer working across enterprise software, systems integration, cloud services, and live-service games."
>
  <section class="hero" aria-labelledby="home-title">
    <div class="hero-identity">
      <p class="identity-name">Veerakran Sereerungruangkul</p>
      <p class="section-label">Backend Developer</p>
    </div>
    <div class="hero-content">
      <h1 id="home-title">Backend systems across live-service games and enterprise software.</h1>
      <p class="hero-summary">
        I research unfamiliar technologies, integrate them into existing systems, and help make
        them reliable in production.
      </p>
      <a class="continue-link" href="#approach">
        Continue to working approach <span aria-hidden="true">&darr;</span>
      </a>
    </div>
  </section>

  <div class="story">
    <section id="approach" class="story-section" aria-labelledby="approach-title">
      <p class="section-label">Working approach</p>
      <div class="trace-content">
        <h2 id="approach-title">How I work</h2>
        <p class="section-intro">
          The recurring pattern throughout my career is learning what a project needs, connecting
          different systems, and carrying the result into production.
        </p>
        <ol class="process-list">
          {workStages.map((stage) => (
            <li>
              <h3>{stage.title}</h3>
              <p>{stage.description}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section id="experience" class="story-section" aria-labelledby="experience-title">
      <p class="section-label">Career range</p>
      <div class="trace-content">
        <h2 id="experience-title">Two industries, similar problems</h2>
        <p class="section-intro">
          My work moved from enterprise and public-sector systems into live-service games. In both
          environments, the useful part was understanding how different systems needed to work
          together.
        </p>
        <div class="career-list">
          {careerChapters.map((chapter) => (
            <article>
              <p class="period">{chapter.period}</p>
              <div>
                <h3>{chapter.title}</h3>
                <p>{chapter.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="story-section" aria-labelledby="work-title">
      <p class="section-label">Project evidence</p>
      <div class="trace-content">
        <h2 id="work-title">Selected work</h2>
        <p class="section-intro">
          A small set of projects showing the range of systems I have worked on and the parts I
          contributed to.
        </p>
        <div class="work-list">
          {selectedWork.map((project) => (
            <a href={project.href}>
              <p class="project-domain">{project.domain}</p>
              <div>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
              </div>
              <span aria-hidden="true">&rarr;</span>
            </a>
          ))}
        </div>
        <a class="text-link" href={projectsHref}>
          Explore all selected projects <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </section>

    <section class="story-section" aria-labelledby="principles-title">
      <p class="section-label">Engineering approach</p>
      <div class="trace-content principles-content">
        <h2 id="principles-title">Practical software over clever software</h2>
        <p class="section-intro">
          Technology choices usually come from project requirements or technical leadership. My
          responsibility is to understand them, implement them carefully, and leave the software
          in a maintainable state.
        </p>
        <ul class="principle-list">
          {principles.map((principle) => <li>{principle}</li>)}
        </ul>
        <a class="text-link" href={resumeHref}>
          Read the full résumé <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .hero,
  .story-section {
    display: grid;
    grid-template-columns: minmax(9rem, 12rem) minmax(0, 1fr);
    column-gap: clamp(2rem, 6vw, 5rem);
  }

  .hero {
    min-height: clamp(34rem, calc(100svh - 5rem), 48rem);
    align-items: start;
    padding-bottom: clamp(5rem, 10vw, 8rem);
  }

  .hero-identity {
    display: grid;
    gap: 0.7rem;
    padding-top: 0.45rem;
  }

  .identity-name,
  .section-label,
  .period,
  .project-domain {
    color: var(--color-muted);
    font-family: var(--font-utility);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .identity-name {
    color: var(--color-text);
    line-height: 1.5;
  }

  .hero-content,
  .trace-content {
    min-width: 0;
  }

  .hero h1 {
    max-width: 56rem;
    font-size: clamp(2.65rem, 6.5vw, 5.5rem);
  }

  .hero-summary {
    max-width: 38rem;
    margin-top: clamp(1.75rem, 4vw, 3rem);
    color: var(--color-muted);
    font-size: clamp(1.1rem, 1rem + 0.6vw, 1.45rem);
    line-height: 1.6;
  }

  .continue-link {
    display: inline-flex;
    gap: 0.65rem;
    margin-top: clamp(3rem, 8vh, 6rem);
    color: var(--color-muted);
    font-family: var(--font-utility);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .story-section {
    scroll-margin-top: 2rem;
  }

  .story-section > .section-label {
    padding-top: clamp(3.35rem, 7vw, 5.85rem);
  }

  .trace-content {
    position: relative;
    padding: clamp(3rem, 7vw, 5.5rem) 0 clamp(4.5rem, 10vw, 8rem)
      clamp(1.75rem, 4vw, 3.5rem);
    border-left: 1px solid var(--color-accent);
  }

  .trace-content::before {
    position: absolute;
    top: clamp(3.65rem, 7vw, 6.15rem);
    left: -0.28rem;
    width: 0.5rem;
    height: 0.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-accent);
    border-radius: 50%;
    content: '';
  }

  .section-intro {
    max-width: var(--reading-width);
    margin-top: 1.5rem;
    color: var(--color-muted);
    font-size: clamp(1.03rem, 1rem + 0.25vw, 1.18rem);
  }

  .process-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 3rem;
    padding: 0;
    border-top: 1px solid var(--color-border);
    list-style: none;
  }

  .process-list li {
    min-height: 13rem;
    padding: 1.6rem clamp(1rem, 2vw, 1.6rem) 1.6rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .process-list li + li {
    padding-left: clamp(1rem, 2vw, 1.6rem);
    border-left: 1px solid var(--color-border);
  }

  .process-list p,
  .career-list article > div > p,
  .work-list a > div > p {
    margin-top: 0.75rem;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .career-list {
    margin-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .career-list article {
    display: grid;
    grid-template-columns: minmax(7rem, 0.5fr) minmax(0, 1.8fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .period {
    padding-top: 0.25rem;
  }

  .work-list {
    margin-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .work-list a {
    display: grid;
    grid-template-columns: minmax(8rem, 0.55fr) minmax(0, 1.5fr) auto;
    gap: clamp(1.25rem, 4vw, 3rem);
    align-items: start;
    padding: 1.75rem 0;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
  }

  .work-list a:hover h3 {
    color: var(--color-accent);
  }

  .work-list a > span {
    color: var(--color-accent);
    font-size: 1.35rem;
  }

  .principle-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 3rem;
    padding: 0;
    border-top: 1px solid var(--color-border);
    list-style: none;
  }

  .principle-list li {
    min-height: 7rem;
    padding: 1.4rem 1.4rem 1.4rem 0;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
  }

  .principle-list li:nth-child(odd) {
    border-right: 1px solid var(--color-border);
  }

  .principle-list li:nth-child(even) {
    padding-left: 1.4rem;
  }

  .text-link {
    display: inline-flex;
    gap: 0.55rem;
    margin-top: 2.5rem;
    font-weight: 650;
  }

  @media (max-width: 48rem) {
    .process-list {
      grid-template-columns: 1fr;
    }

    .process-list li {
      min-height: 0;
      padding: 1.4rem 0;
    }

    .process-list li + li {
      padding-left: 0;
      border-left: 0;
    }
  }

  @media (max-width: 45rem) {
    .hero,
    .story-section {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: calc(100svh - 7rem);
      gap: 2rem;
      padding-bottom: 5rem;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
    }

    .continue-link {
      margin-top: clamp(3rem, 10vh, 5rem);
    }

    .story-section > .section-label {
      padding-top: 0;
    }

    .trace-content {
      margin-top: 0.85rem;
      padding: 2.5rem 0 5rem;
      border-top: 1px solid var(--color-accent);
      border-left: 0;
    }

    .trace-content::before {
      top: -0.28rem;
      left: 0;
    }

    .career-list article,
    .work-list a {
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }

    .work-list a > span {
      display: none;
    }
  }

  @media (max-width: 32rem) {
    .principle-list {
      grid-template-columns: 1fr;
    }

    .principle-list li,
    .principle-list li:nth-child(even),
    .principle-list li:nth-child(odd) {
      min-height: 0;
      padding: 1.25rem 0;
      border-right: 0;
    }
  }
</style>
