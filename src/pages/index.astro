---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/paths';

const workStages = [
  { title: 'Learn', description: 'Understand an unfamiliar system, its constraints, and how it fits the project.' },
  { title: 'Integrate', description: 'Connect it to existing APIs, data, services, applications, or hardware.' },
  { title: 'Deliver', description: 'Make the result reliable enough for production, deployment, and maintenance.' },
];

const careerChapters = [
  {
    period: '2018–2021', title: 'Enterprise software',
    description: 'I developed software for government agencies, public organisations, and private-sector clients—from database-driven web applications to Windows software, kiosks, and specialised hardware integration.',
  },
  {
    period: '2021–2026', title: 'Live-service games',
    description: 'The industry changed, but the engineering pattern remained familiar: backend APIs, shared player services, multiplayer platforms, payments, communication services, and production deployments.',
  },
];

const selectedWork = [
  { domain: 'Live-service games', title: 'Tiny Little Platform', description: 'Shared backend services supporting seven commercial games across browser and mobile releases.', href: withBase('projects/tiny-little-platform/') },
  { domain: 'Desktop software', title: 'RentPilot', description: 'An offline Windows dormitory management application deployed for an active client.', href: withBase('projects/rentpilot/') },
];

const principles = [
  'Maintainable enough for another developer to understand.',
  'Reliable under the conditions where it will actually run.',
  'Simple enough to change when project requirements move.',
  'Appropriate for the problem rather than the current trend.',
];
---

<BaseLayout title="Backend Developer" description="Veerakran Sereerungruangkul is a Backend Developer working across enterprise software, systems integration, cloud services, and live-service games.">
  <section class="hero" aria-labelledby="home-title">
    <svg class="hero-trace" viewBox="0 0 1000 620" aria-hidden="true">
      <path class="trace trace-a" d="M50 116H244V250H414" />
      <path class="trace trace-b" d="M950 474H756V340H586" />
      <path class="trace trace-c" d="M500 32V168M500 452V588" />
      <circle cx="244" cy="250" r="5" /><circle cx="756" cy="340" r="5" />
      <circle cx="500" cy="168" r="5" /><circle cx="500" cy="452" r="5" />
    </svg>
    <div class="hero-copy">
      <p class="hero-kicker">Portfolio / Backend engineering</p>
      <h1 id="home-title">Veerakran <span>Sereerungruangkul</span></h1>
      <div class="profession" aria-label="Professional focus">
        <p>Backend Developer</p><span aria-hidden="true">·</span>
        <p>Platform &amp; Systems Integration</p><span aria-hidden="true">·</span>
        <p>Cloud &amp; Live-Service Games</p>
      </div>
    </div>
    <a class="continue-link" href="#introduction">Explore <span aria-hidden="true">↓</span></a>
  </section>

  <div class="story" id="introduction">
    <section class="intro-section" aria-labelledby="intro-title">
      <p class="section-label">Introduction</p>
      <div class="trace-content">
        <h2 id="intro-title">Backend systems across live-service games and enterprise software.</h2>
        <p class="lead">I research unfamiliar technologies, integrate them into existing systems, and help make them reliable in production.</p>
      </div>
    </section>

    <section class="story-section" aria-labelledby="approach-title">
      <p class="section-label">Working approach</p>
      <div class="trace-content">
        <h2 id="approach-title">How I work</h2>
        <p class="section-intro">The recurring pattern throughout my career is learning what a project needs, connecting different systems, and carrying the result into production.</p>
        <ol class="process-list">{workStages.map((stage) => <li><h3>{stage.title}</h3><p>{stage.description}</p></li>)}</ol>
      </div>
    </section>

    <section id="experience" class="story-section" aria-labelledby="experience-title">
      <p class="section-label">Career range</p>
      <div class="trace-content">
        <h2 id="experience-title">Two industries, similar problems</h2>
        <p class="section-intro">My work moved from enterprise and public-sector systems into live-service games. In both environments, the useful part was understanding how different systems needed to work together.</p>
        <div class="career-list">{careerChapters.map((chapter) => <article><p class="period">{chapter.period}</p><div><h3>{chapter.title}</h3><p>{chapter.description}</p></div></article>)}</div>
      </div>
    </section>

    <section class="story-section" aria-labelledby="work-title">
      <p class="section-label">Project evidence</p>
      <div class="trace-content">
        <h2 id="work-title">Selected work</h2>
        <p class="section-intro">A small set of projects showing the range of systems I have worked on and the parts I contributed to.</p>
        <div class="work-list">{selectedWork.map((project) => <a href={project.href}><p class="project-domain">{project.domain}</p><div><h3>{project.title}</h3><p>{project.description}</p></div><span aria-hidden="true">↗</span></a>)}</div>
        <a class="text-link" href={withBase('projects/')}>Explore all selected projects <span aria-hidden="true">→</span></a>
      </div>
    </section>

    <section class="story-section" aria-labelledby="principles-title">
      <p class="section-label">Engineering approach</p>
      <div class="trace-content">
        <h2 id="principles-title">Practical software over clever software</h2>
        <p class="section-intro">Technology choices usually come from project requirements or technical leadership. My responsibility is to understand them, implement them carefully, and leave the software in a maintainable state.</p>
        <ul class="principle-list">{principles.map((principle) => <li>{principle}</li>)}</ul>
        <a class="text-link" href={withBase('resume')}>Read the full résumé <span aria-hidden="true">→</span></a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .hero { position: relative; display: grid; place-items: center; min-height: calc(100svh - 8rem); overflow:hidden; text-align: center; isolation: isolate; }
  .hero-copy { display: grid; justify-items: center; max-width: 70rem; animation: reveal 800ms cubic-bezier(.2,.7,.2,1) both; }
  .hero-kicker,.section-label,.period,.project-domain { color:var(--color-muted); font:600 .7rem/1.5 var(--font-utility); letter-spacing:.09em; text-transform:uppercase; }
  .hero h1 { max-width: 100%; margin-top: 1.25rem; font-size:clamp(2.8rem,8.5vw,7.5rem); line-height:.94; letter-spacing:-.055em; overflow-wrap:normal; }
  .hero h1 span { display:block; }
  .profession { display:flex; flex-wrap:wrap; justify-content:center; gap:.5rem .85rem; margin-top:clamp(1.75rem,4vw,2.75rem); color:var(--color-muted); font-size:clamp(.88rem,1.4vw,1rem); }
  .profession span { color:var(--color-accent); }
  .hero-trace { position:absolute; inset:5% 0; z-index:-1; width:100%; height:90%; color:var(--color-accent); opacity:.35; }
  .hero-trace path { fill:none; stroke:currentColor; stroke-width:1; stroke-dasharray:800; animation:draw 1200ms 160ms ease-out both; }
  .hero-trace circle { fill:var(--color-bg); stroke:currentColor; stroke-width:1.5; }
  .continue-link { position:absolute; bottom:1.5rem; display:flex; gap:.7rem; color:var(--color-muted); font:600 .7rem var(--font-utility); letter-spacing:.08em; text-decoration:none; text-transform:uppercase; }
  .story { scroll-margin-top:2rem; }
  .intro-section,.story-section { display:grid; grid-template-columns:minmax(9rem,12rem) minmax(0,1fr); column-gap:clamp(2rem,6vw,5rem); }
  .intro-section > .section-label,.story-section > .section-label { padding-top:clamp(3.35rem,7vw,5.85rem); }
  .trace-content { position:relative; min-width:0; padding:clamp(3rem,7vw,5.5rem) 0 clamp(4.5rem,10vw,8rem) clamp(1.75rem,4vw,3.5rem); border-left:1px solid var(--color-accent); }
  .trace-content::before { content:""; position:absolute; top:clamp(3.55rem,7vw,6.05rem); left:-.3rem; width:.55rem; height:.55rem; background:var(--color-bg); border:1px solid var(--color-accent); border-radius:50%; }
  .intro-section h2 { max-width:48rem; font-size:clamp(2.25rem,5vw,4.4rem); }
  .lead,.section-intro { max-width:42rem; margin-top:1.5rem; color:var(--color-muted); font-size:clamp(1.04rem,1rem + .3vw,1.22rem); }
  .process-list { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; margin:3rem 0 0; padding:1px; background:var(--color-border); list-style:none; }
  .process-list li { padding:clamp(1.25rem,3vw,2rem); background:var(--color-bg); }
  .process-list p,.career-list p,.work-list p,.principle-list { margin-top:.65rem; color:var(--color-muted); }
  .career-list { margin-top:3rem; border-top:1px solid var(--color-border); }
  .career-list article { display:grid; grid-template-columns:minmax(8rem,.55fr) 2fr; gap:2rem; padding:2rem 0; border-bottom:1px solid var(--color-border); }
  .career-list .period { margin-top:.25rem; }
  .work-list { margin:3rem 0 2rem; border-top:1px solid var(--color-border); }
  .work-list a { display:grid; grid-template-columns:minmax(9rem,.7fr) 2fr auto; gap:1.5rem; align-items:start; padding:1.5rem 0; color:var(--color-text); border-bottom:1px solid var(--color-border); text-decoration:none; }
  .work-list a:hover h3 { color:var(--color-accent); }
  .project-domain { margin-top:.2rem!important; }
  .principle-list { display:grid; gap:.6rem; margin:2rem 0 2.5rem; padding-left:1.2rem; }
  .text-link { font-weight:650; }
  @keyframes draw { from { stroke-dashoffset:800; opacity:0; } to { stroke-dashoffset:0; opacity:1; } }
  @keyframes reveal { from { opacity:0; transform:translateY(1rem); } to { opacity:1; transform:none; } }
  @media (max-width:45rem) {
    .hero { min-height:calc(100svh - 10rem); }
    .hero h1 { font-size:clamp(1.75rem,8vw,3.5rem); }
    .profession { flex-direction:column; gap:.25rem; }
    .profession span { display:none; }
    .hero-trace { inset:12% -25%; width:150%; height:76%; }
    .intro-section,.story-section { grid-template-columns:1fr; }
    .intro-section > .section-label,.story-section > .section-label { padding-top:0; }
    .trace-content { margin-top:.85rem; padding:2.5rem 0 5rem; border-top:1px solid var(--color-accent); border-left:0; }
    .trace-content::before { top:-.3rem; left:0; }
    .process-list { grid-template-columns:1fr; }
    .career-list article,.work-list a { grid-template-columns:1fr; gap:.5rem; }
    .work-list a > span { position:absolute; right:0; }
    .work-list a { position:relative; padding-right:2rem; }
  }
  @media (prefers-reduced-motion:reduce) { .hero-copy,.hero-trace path { animation:none; } }
</style>
