---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MediaGallery from '../../components/MediaGallery.astro';
import { projects, type Project } from '../../data/projects';
import { withBase } from '../../utils/paths';

export function getStaticPaths() {
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}
interface Props { project: Project }
const { project } = Astro.props;
const index = projects.findIndex((item) => item.slug === project.slug);
const nextProject = projects[(index + 1) % projects.length];
---
<BaseLayout title={project.title} description={`${project.summary} Selected work by Veerakran Sereerungruangkul.`}>
  <article class="project-detail">
    <a class="back-link" href={withBase('projects/')}><span aria-hidden="true">←</span> Selected projects</a>
    <header class="project-hero">
      <p class="kicker">{project.domain}</p>
      <h1>{project.title}</h1>
      <p class="project-summary">{project.summary}</p>
      <p class="project-description">{project.description}</p>
      <div class="project-actions">
        {project.links?.map((link) => <a class="text-link" href={link.href}>{link.label} <span aria-hidden="true">↗</span></a>)}
        {project.demoSoon && <span class="text-link is-disabled">{project.demoSoon}</span>}
        {project.status && <p class="status"><span aria-hidden="true"></span>{project.status}</p>}
      </div>
    </header>

    <MediaGallery media={project.media} />

    <section class="project-context" aria-labelledby="contribution-title">
      <div><p class="kicker">Contribution</p><h2 id="contribution-title">What I worked on</h2></div>
      <div>
        <ul>{project.contributions.map((contribution) => <li>{contribution}</li>)}</ul>
        <aside><h3>{project.scopeLabel}</h3><p>{project.scope}</p></aside>
      </div>
    </section>

    {project.products && (
      <section class="products" aria-labelledby="products-title">
        <header><p class="kicker">Public releases</p><h2 id="products-title">Related products</h2><p>Store artwork is represented by temporary lettermarks until approved assets are available.</p></header>
        <div class="product-grid">{project.products.map((product) => <article><img src={withBase(product.icon)} alt="" width="96" height="96" loading="lazy" /><div><h3>{product.name}</h3>{product.note && <p>{product.note}</p>}<div class="store-links">{product.links.map((link) => <a href={link.href} aria-label={link.label}>{link.label.includes('Google') ? 'Google Play' : 'App Store'} <span aria-hidden="true">↗</span></a>)}</div></div></article>)}</div>
      </section>
    )}

    <a class="next-project" href={withBase(`projects/${nextProject.slug}/`)}><span><small>Next project</small>{nextProject.title}</span><b aria-hidden="true">→</b></a>
  </article>
</BaseLayout>
<style>
  .project-detail { max-width:60rem; margin-inline:auto; }
  .back-link { display:inline-flex; gap:.6rem; color:var(--color-muted); font:600 var(--text-label) var(--font-utility); text-decoration:none; text-transform:uppercase; letter-spacing:.07em; }
  .project-hero { max-width:48rem; padding:clamp(2rem,5vw,3.5rem) 0 clamp(2rem,4vw,3rem); }
  .project-context h3,.next-project small { color:var(--color-muted); font:600 var(--text-label)/1.5 var(--font-utility); text-transform:uppercase; letter-spacing:.09em; }
  .project-hero h1 { margin-top:.75rem; font-size:var(--text-section); }
  .project-summary { max-width:40rem; margin-top:1rem; font-size:var(--text-lead); }
  .project-description { max-width:38rem; margin-top:.75rem; color:var(--color-muted); }
  .project-actions { display:flex; flex-wrap:wrap; gap:.75rem 1rem; align-items:center; margin-top:1.5rem; }
  .text-link.is-disabled { color:var(--color-muted); text-decoration:none; }
  .status { display:flex; gap:.6rem; align-items:center; color:var(--color-muted); font:600 var(--text-label) var(--font-utility); text-transform:uppercase; letter-spacing:.05em; }
  .status span { width:.5rem; height:.5rem; border:1px solid var(--color-accent); border-radius:50%; }
  .project-context { margin-top:clamp(3rem,6vw,4.5rem); padding-top:clamp(1.5rem,3vw,2.5rem); border-top:1px solid var(--color-accent); }
  .project-context > div + div { margin-top:1.5rem; }
  .project-context h2,.products h2 { margin-top:.5rem; }
  .project-context ul { display:grid; gap:.7rem; margin:0; padding-left:1.2rem; color:var(--color-muted); }
  .project-context aside { margin-top:1.5rem; padding-left:1.2rem; border-left:1px solid var(--color-border); }
  .project-context aside p { margin-top:.5rem; color:var(--color-muted); }
  .products { margin-top:clamp(3rem,6vw,4.5rem); }
  .products > header { padding-bottom:1.25rem; border-bottom:1px solid var(--color-border); }
  .products > header p:last-child { margin-top:.6rem; color:var(--color-muted); font-size:var(--text-supporting); }
  .product-grid { display:grid; grid-template-columns:repeat(2,1fr); }
  .product-grid article { display:grid; grid-template-columns:3.5rem 1fr; gap:1rem; padding:1.25rem 0; border-bottom:1px solid var(--color-border); }
  .product-grid article:nth-child(odd) { padding-right:1.25rem; border-right:1px solid var(--color-border); }
  .product-grid img { width:3.5rem; height:3.5rem; border-radius:.8rem; }
  .product-grid p { margin-top:.3rem; color:var(--color-muted); font-size:var(--text-supporting); }
  .store-links { display:flex; flex-wrap:wrap; gap:.4rem .75rem; margin-top:.6rem; }
  .store-links a { font-size:var(--text-supporting); }
  .next-project { display:flex; justify-content:space-between; align-items:center; gap:2rem; margin-top:clamp(3rem,7vw,5rem); padding:1.5rem 0; color:var(--color-text); border-block:1px solid var(--color-border); font:650 clamp(1.1rem,2.5vw,1.6rem) var(--font-heading); text-decoration:none; }
  .next-project small { display:block; margin-bottom:.3rem; }
  .next-project b { color:var(--color-accent); font-size:1.6rem; }
  @media(max-width:48rem){ .product-grid { grid-template-columns:1fr; } .product-grid article:nth-child(odd){border-right:0;padding-right:0;} }
</style>
