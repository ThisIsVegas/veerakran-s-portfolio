---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';
import { withBase } from '../../utils/paths';
---
<BaseLayout title="Selected Projects" description="Selected backend, systems integration, live-service game, enterprise, and desktop software projects by Veerakran Sereerungruangkul.">
  <header class="projects-hero">
    <p class="kicker">Selected work / 2018–2026</p>
    <h1>Selected projects</h1>
    <p>A concise record of production work across backend platforms, enterprise systems, and desktop software. Confidential implementation details remain out of scope.</p>
  </header>

  <div class="project-list">
    {projects.map((project, index) => {
      const featured = project.media.find((item) => item.type === 'video') ?? project.media[0];
      return (
        <section class="project-record" aria-labelledby={`${project.slug}-title`}>
          <div class="project-copy">
            <p class="project-number">{String(index + 1).padStart(2, '0')} / {project.domain}</p>
            <h2 id={`${project.slug}-title`}><a href={withBase(`projects/${project.slug}/`)}>{project.title}</a></h2>
            <p>{project.summary}</p>
            <div class="project-actions">
              {project.links?.map((link) => <a class="text-link" href={link.href}>{link.label} <span aria-hidden="true">↗</span></a>)}
              {project.demoSoon && <span class="text-link is-disabled">{project.demoSoon}</span>}
              {project.products && (
                <div class="app-badges">
                  {project.products.map((product) => (
                    <a href={product.links[0].href} aria-label={product.links[0].label}>
                      <img src={withBase(product.icon)} alt="" width="32" height="32" loading="lazy" />
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
          <a class="project-media" href={withBase(`projects/${project.slug}/`)} aria-label={`View ${project.title} media`}>
            {featured?.type === 'video' ? (
              <video autoplay muted loop playsinline preload="metadata" poster={withBase(featured.poster)}>
                <source src={withBase(featured.src)} />
              </video>
            ) : featured ? (
              <img src={withBase(featured.src)} alt={featured.alt} width="1200" height="720" loading={index ? 'lazy' : 'eager'} decoding="async" />
            ) : null}
          </a>
        </section>
      );
    })}
  </div>
</BaseLayout>

<style>
  .projects-hero { max-width: 44rem; padding-bottom: clamp(3rem, 7vw, 5rem); }
  .projects-hero > p:last-child { margin-top: 1rem; color: var(--color-muted); }
  .project-list { display: grid; gap: clamp(3.5rem, 8vw, 6rem); }
  .project-record { display: grid; grid-template-columns: minmax(16rem, 1.3fr) 22rem; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; }
  .project-media { display: block; justify-self: end; width: 100%; max-width: 22rem; aspect-ratio: 16/9; overflow: hidden; border: 1px solid var(--color-border); background: var(--color-surface); }
  .project-media img, .project-media video { display: block; width: 100%; height: 100%; object-fit: cover; }
  .project-number { margin-bottom: .6rem; color: var(--color-muted); font: 600 var(--text-label)/1.5 var(--font-utility); letter-spacing: .08em; text-transform: uppercase; }
  .project-copy h2 { margin-bottom: .8rem; }
  .project-copy h2 a { color: inherit; text-decoration: none; }
  .project-copy h2 a:hover { color: var(--color-accent); }
  .project-copy > p { color: var(--color-muted); }
  .project-actions { display: flex; flex-wrap: wrap; gap: .75rem 1.5rem; align-items: center; margin-top: 1.25rem; }
  .text-link.is-disabled { color: var(--color-muted); text-decoration: none; }
  .app-badges { display: flex; gap: .6rem; }
  .app-badges img { display: block; width: 2rem; height: 2rem; }
  @media(max-width: 48rem) { .project-record { grid-template-columns: 1fr; } .project-media { justify-self: stretch; max-width: none; } }
</style>
