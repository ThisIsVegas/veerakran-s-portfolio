---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { professionalExperience, projects } from '../../data/projects';
import { withBase } from '../../utils/paths';
---
<BaseLayout title="Selected Projects" description="Selected backend, systems integration, live-service game, enterprise, and desktop software projects by Veerakran Sereerungruangkul.">
  <header class="projects-hero">
    <p class="kicker">Selected work / 2018–2026</p>
    <h1>Selected projects</h1>
    <p>Public case studies and professional project work across backend platforms, enterprise systems, and desktop software.</p>
    <nav class="project-sections" aria-label="Project sections">
      <a href="#public-case-studies">
        <span>Public case studies</span>
        <small>Projects with public details and media</small>
      </a>
      <a href="#professional-project-experience">
        <span>Professional project experience</span>
        <small>Earlier client and public-sector work</small>
      </a>
    </nav>
  </header>

  <section class="project-section public-work" id="public-case-studies" aria-labelledby="public-case-studies-title">
    <header class="section-heading">
      <div>
        <p class="kicker">Detailed work</p>
        <h2 id="public-case-studies-title">Public case studies</h2>
      </div>
      <p>Projects with enough public information to show the work, contribution, and production context in detail.</p>
    </header>

    <div class="project-list">
      {projects.map((project, index) => {
        const featured = project.media[0];
        const extraVideos = project.media.slice(1).filter((item) => item.type === 'video');
        return (
          <article class="project-record" aria-labelledby={`${project.slug}-title`}>
            <div class="project-copy">
              <p class="project-number">{String(index + 1).padStart(2, '0')} / {project.domain}</p>
              <h3 id={`${project.slug}-title`}><a href={withBase(`projects/${project.slug}/`)}>{project.title}</a></h3>
              <p>{project.summary}</p>
              <div class="project-actions">
                {project.links?.map((link) => <a class="text-link" href={link.href}>{link.label} <span aria-hidden="true">↗</span></a>)}
                {project.demoSoon && <span class="text-link is-disabled">{project.demoSoon}</span>}
                {project.products && (
                  <div class="app-badges">
                    {project.products.map((product) => (
                      <a href={product.links[0].href} aria-label={product.links[0].label}>
                        <img src={withBase(product.icon)} alt="" width="32" height="32" loading="lazy" />
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </div>
            <div class="project-media-group">
              <a class="project-media" href={withBase(`projects/${project.slug}/`)} aria-label={`View ${project.title} media`}>
                {featured?.type === 'video' ? (
                  <video autoplay muted loop playsinline preload="metadata" poster={withBase(featured.poster)}>
                    <source src={withBase(featured.src)} />
                  </video>
                ) : featured ? (
                  <img src={withBase(featured.src)} alt={featured.alt} width="1200" height="720" loading={index ? 'lazy' : 'eager'} decoding="async" />
                ) : null}
              </a>
              {extraVideos.length > 0 && (
                <div class="project-media-row">
                  {extraVideos.map((item) => item.type === 'video' && (
                    <a class="project-media project-media--small" href={withBase(`projects/${project.slug}/`)} aria-label={item.caption}>
                      <video autoplay muted loop playsinline preload="metadata" poster={withBase(item.poster)}>
                        <source src={withBase(item.src)} />
                      </video>
                    </a>
                  ))}
                </div>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section class="project-section professional-work" id="professional-project-experience" aria-labelledby="professional-project-experience-title">
    <header class="section-heading professional-heading">
      <div>
        <p class="kicker">Professional employment / 2018–2021</p>
        <h2 id="professional-project-experience-title">Professional project experience</h2>
      </div>
      <p>Earlier professional work across enterprise and public-sector software. Client and organisation names are omitted to respect confidentiality.</p>
    </header>

    <div class="workstream-list">
      {professionalExperience.map((workstream) => (
        <article class="workstream">
          <h3>{workstream.title}</h3>
          <div class="workstream-detail">
            <p>{workstream.summary}</p>
            <div class="systems-line">
              <p>Systems involved</p>
              <ul aria-label={`Systems involved in ${workstream.title}`}>
                {workstream.systems.map((system) => <li>{system}</li>)}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>

    <section class="work-closing" aria-labelledby="work-closing-title">
      <p class="kicker">Across the work</p>
      <div>
        <h3 id="work-closing-title">Work beyond the public case studies</h3>
        <p>Across these projects, my role was often to research unfamiliar technologies, integrate them into existing systems, and make them reliable in production.</p>
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  .projects-hero { max-width: 58rem; padding-bottom: clamp(4rem, 9vw, 7rem); }
  .projects-hero > h1 + p { margin-top: 1rem; color: var(--color-muted); }
  .project-sections { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); margin-top: clamp(2rem, 5vw, 3.5rem); border-block: 1px solid var(--color-border); }
  .project-sections a { display: grid; gap: .2rem; padding: 1rem 1.25rem 1rem 0; color: var(--color-text); text-decoration: none; }
  .project-sections a + a { padding-left: 1.25rem; border-left: 1px solid var(--color-border); }
  .project-sections span { font-family: var(--font-heading); font-weight: 650; }
  .project-sections small { color: var(--color-muted); font-size: var(--text-label); line-height: 1.45; }
  .project-sections a:hover span { color: var(--color-accent); }
  .project-section { scroll-margin-top: calc(var(--header-height) + 1.5rem); }
  .section-heading { display: grid; grid-template-columns: minmax(16rem, 1fr) minmax(20rem, 1fr); gap: clamp(1.5rem, 5vw, 5rem); align-items: end; margin-bottom: clamp(2.5rem, 6vw, 4.5rem); padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .section-heading .kicker { margin-bottom: .55rem; }
  .section-heading > p { max-width: 38rem; color: var(--color-muted); }
  .project-list { display: grid; gap: clamp(3.5rem, 8vw, 6rem); }
  .project-record { display: grid; grid-template-columns: minmax(16rem, 1.3fr) 22rem; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; }
  .project-media-group { justify-self: end; width: 100%; max-width: 22rem; display: grid; gap: .6rem; }
  .project-media { display: block; width: 100%; aspect-ratio: 16/9; overflow: hidden; border: 1px solid var(--color-border); background: var(--color-surface); }
  .project-media img, .project-media video { display: block; width: 100%; height: 100%; object-fit: cover; }
  .project-media-row { display: grid; grid-template-columns: repeat(2, 1fr); gap: .6rem; }
  .project-number { margin-bottom: .6rem; color: var(--color-muted); font: 600 var(--text-label)/1.5 var(--font-utility); letter-spacing: .08em; text-transform: uppercase; }
  .project-copy h3 { margin-bottom: .8rem; font-size: var(--text-section); }
  .project-copy h3 a { color: inherit; text-decoration: none; }
  .project-copy h3 a:hover { color: var(--color-accent); }
  .project-copy > p { color: var(--color-muted); }
  .project-actions { display: flex; flex-wrap: wrap; gap: .75rem 1.5rem; align-items: center; margin-top: 1.25rem; }
  .text-link.is-disabled { color: var(--color-muted); text-decoration: none; }
  .app-badges { display: flex; gap: .6rem; }
  .app-badges img { display: block; width: 2rem; height: 2rem; }
  .professional-work { margin-top: clamp(6rem, 13vw, 10rem); }
  .workstream-list { border-top: 1px solid var(--color-border); }
  .workstream { display: grid; grid-template-columns: minmax(14rem, .85fr) minmax(20rem, 1.45fr); gap: clamp(1.5rem, 5vw, 5rem); padding-block: clamp(2rem, 5vw, 3.25rem); border-bottom: 1px solid var(--color-border); }
  .workstream h3 { max-width: 22rem; font-size: clamp(1.25rem, 1.1rem + .7vw, 1.7rem); }
  .workstream-detail > p { max-width: 42rem; font-size: var(--text-lead); line-height: 1.55; }
  .systems-line { display: grid; gap: .45rem; margin-top: 1.35rem; }
  .systems-line > p { color: var(--color-muted); font: 600 var(--text-label)/1.5 var(--font-utility); letter-spacing: .08em; text-transform: uppercase; }
  .systems-line ul { display: flex; flex-wrap: wrap; gap: .15rem .55rem; padding: 0; color: var(--color-muted); font-size: var(--text-supporting); line-height: 1.55; list-style: none; }
  .systems-line li:not(:last-child)::after { margin-left: .55rem; color: var(--color-border); content: '·'; }
  .work-closing { display: grid; grid-template-columns: minmax(11rem, .65fr) minmax(20rem, 1.65fr); gap: clamp(1.5rem, 5vw, 5rem); margin-top: clamp(4rem, 9vw, 7rem); padding: clamp(2rem, 6vw, 4.5rem); border: 1px solid var(--color-border); background: var(--color-surface); }
  .work-closing .kicker { align-self: start; }
  .work-closing h3 { max-width: 42rem; font-size: var(--text-section); }
  .work-closing div > p { max-width: 44rem; margin-top: 1.25rem; color: var(--color-muted); font-size: var(--text-lead); }
  @media(max-width: 48rem) {
    .project-sections, .section-heading, .project-record, .workstream, .work-closing { grid-template-columns: 1fr; }
    .project-sections a + a { padding-left: 0; border-top: 1px solid var(--color-border); border-left: 0; }
    .project-media-group { justify-self: stretch; max-width: none; }
    .section-heading { align-items: start; }
    .workstream { gap: 1rem; }
  }
</style>
