---
interface Props {
  slug: string;
  title: string;
  summary: string;
  technologies: string[];
}

const { slug, title, summary, technologies } = Astro.props;
---

<article class="project-card">
  <h3><a href={`/projects/${slug}`}>{title}</a></h3>
  <p>{summary}</p>
  <ul class="tech-list">
    {technologies.map((tech) => <li>{tech}</li>)}
  </ul>
</article>

<style>
  .project-card {
    padding: var(--spacing-3) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .tech-list {
    list-style: none;
    margin: var(--spacing-1) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--color-muted);
    font-size: 0.85rem;
  }
</style>
