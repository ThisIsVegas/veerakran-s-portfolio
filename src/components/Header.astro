---
import Nav from './Nav.astro';
import ThemeControl from './ThemeControl.astro';
import { withBase, withoutBase } from '../utils/paths';

const homeHref = withBase();
const isHomepage = withoutBase(Astro.url.pathname) === '/';
---

<header data-homepage={isHomepage ? 'true' : undefined}>
  <div class="header-inner">
    <a class="site-identity" href={homeHref}>Veerakran S.</a>
    <div class="header-controls">
      <div class="nav-slot"><Nav /></div>
      <div class="theme-slot"><ThemeControl /></div>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('header');
  if (header) {
    const updateScrolled = () => {
      header.dataset.scrolled = window.scrollY > 0 ? 'true' : 'false';
    };
    updateScrolled();
    window.addEventListener('scroll', updateScrolled, { passive: true });
  }
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    border-bottom: 1px solid transparent;
    background: transparent;
    transition: background-color 200ms ease, border-color 200ms ease;
  }

  :global(:root) {
    --header-height: 4.5rem;
  }

  @media (max-width: 35rem) {
    :global(:root) {
      --header-height: 7rem;
    }
  }

  header[data-scrolled='true'] {
    border-bottom-color: var(--color-border);
    background: var(--color-bg);
  }

  header:not([data-homepage='true']) .site-identity {
    opacity: 1;
    transform: none;
  }

  header[data-homepage='true'] .site-identity {
    opacity: 0;
    transform: translateY(-0.4rem);
  }

  @media (prefers-reduced-motion: reduce) {
    header[data-homepage='true'] .site-identity {
      opacity: 1;
      transform: none;
    }
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-2);
    max-width: var(--site-width);
    margin-inline: auto;
    padding: var(--spacing-2);
  }

  .site-identity {
    color: var(--color-text);
    font-weight: 700;
    text-decoration: none;
    transition: opacity 200ms ease, transform 200ms ease;
  }

  .site-identity:hover {
    color: var(--color-accent);
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: clamp(0.85rem, 3vw, 2rem);
  }

  @media (max-width: 35rem) {
    .header-inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      row-gap: 0.8rem;
    }

    .site-identity {
      grid-column: 1 / -1;
      grid-row: 1;
    }

    .header-controls {
      display: contents;
    }

    .nav-slot {
      min-width: 0;
      grid-column: 1;
      grid-row: 2;
    }

    .theme-slot {
      grid-column: 2;
      grid-row: 2;
      align-self: center;
    }
  }
</style>
