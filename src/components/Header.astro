---
import Nav from './Nav.astro';
import ThemeControl from './ThemeControl.astro';
import { withBase } from '../utils/paths';

const homeHref = withBase();
---

<header>
  <div class="header-inner">
    <a class="site-identity" href={homeHref}>Veerakran S.</a>
    <div class="header-controls">
      <div class="nav-slot"><Nav /></div>
      <div class="theme-slot"><ThemeControl /></div>
    </div>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-2);
    max-width: var(--site-width);
    margin-inline: auto;
    padding: var(--spacing-2);
  }

  .site-identity {
    color: var(--color-text);
    font-weight: 700;
    text-decoration: none;
  }

  .site-identity:hover {
    color: var(--color-accent);
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: clamp(0.85rem, 3vw, 2rem);
  }

  @media (max-width: 35rem) {
    .header-inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      row-gap: 0.8rem;
    }

    .header-controls {
      display: contents;
    }

    .nav-slot {
      grid-column: 1 / -1;
      grid-row: 2;
    }

    .theme-slot {
      grid-column: 2;
      grid-row: 1;
    }
  }
</style>
