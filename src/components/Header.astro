---
import Nav from './Nav.astro';
import ThemeControl from './ThemeControl.astro';
import { withoutBase } from '../utils/paths';

const isHomepage = withoutBase(Astro.url.pathname) === '/';
---

<header data-homepage={isHomepage ? 'true' : undefined}>
  <div class="header-inner">
    <div class="nav-slot"><Nav /></div>
    <div class="theme-slot"><ThemeControl /></div>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    backdrop-filter: blur(0.5rem);
    -webkit-backdrop-filter: blur(0.5rem);
  }

  :global(:root) {
    --header-height: 5rem;
  }

  @media (max-width: 35rem) {
    :global(:root) {
      --header-height: 7.5rem;
    }
  }

  header[data-homepage='true'] {
    opacity: 0;
    transform: translateY(-0.6rem);
    pointer-events: none;
  }

  header[data-homepage='true'][data-hero-full-view='false'] {
    opacity: 1;
    transform: none;
    pointer-events: auto;
    transition: opacity 300ms ease, transform 300ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    header[data-homepage='true'][data-hero-full-view='false'] {
      transition: none;
    }
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-2);
    max-width: var(--site-width);
    margin-inline: auto;
    padding: var(--spacing-3) var(--spacing-2);
  }

  .nav-slot {
    min-width: 0;
  }
</style>
