---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="section-heading">
  <h2>{title}</h2>
  {subtitle && <p class="subtitle">{subtitle}</p>}
</div>

<style>
  .section-heading {
    margin-bottom: var(--spacing-2);
  }

  .subtitle {
    color: var(--color-muted);
    margin-top: 0.25rem;
  }
</style>
