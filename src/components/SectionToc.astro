---
interface Section {
  id: string;
  label: string;
}

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

<nav class="section-toc" aria-label="Page sections" data-section-toc>
  <p>On this page</p>
  <ol>
    {sections.map((section) => (
      <li>
        <a href={`#${section.id}`} data-toc-link={section.id}>{section.label}</a>
      </li>
    ))}
  </ol>
</nav>

<script>
  const toc = document.querySelector<HTMLElement>('[data-section-toc]');
  if (toc) {
    const links = new Map(
      Array.from(toc.querySelectorAll<HTMLAnchorElement>('[data-toc-link]')).map((link) => [
        link.dataset.tocLink,
        link,
      ]),
    );

    const setActive = (id: string) => {
      links.forEach((link, linkId) => {
        if (linkId === id) link.setAttribute('aria-current', 'true');
        else link.removeAttribute('aria-current');
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((entry) => entry.isIntersecting);
        if (visible.length === 0) return;
        const topmost = visible.reduce((a, b) => (a.boundingClientRect.top < b.boundingClientRect.top ? a : b));
        setActive(topmost.target.id);
      },
      { rootMargin: '-15% 0px -70% 0px' },
    );

    links.forEach((_, id) => {
      const section = id ? document.getElementById(id) : null;
      if (section) observer.observe(section);
    });
  }
</script>

<style>
  .section-toc {
    position: sticky;
    top: calc(var(--header-height) + 1.5rem);
    align-self: start;
  }

  .section-toc > p {
    margin-bottom: 1rem;
    color: var(--color-muted);
    font-family: var(--font-utility);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-toc ol {
    display: grid;
    gap: 0.25rem;
    list-style: none;
  }

  .section-toc a {
    display: block;
    padding: 0.5rem 0;
    color: var(--color-muted);
    font-size: var(--text-supporting);
    line-height: 1.4;
    text-decoration: none;
  }

  .section-toc a:hover {
    color: var(--color-text);
  }

  .section-toc a[aria-current='true'] {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-decoration-thickness: 0.12rem;
    text-underline-offset: 0.3em;
  }

  @media (max-width: 52rem) {
    .section-toc {
      position: static;
      overflow-x: auto;
    }

    .section-toc > p {
      display: none;
    }

    .section-toc ol {
      display: flex;
      width: max-content;
      gap: 0;
    }

    .section-toc a {
      padding: 0.75rem 1.25rem 0.75rem 0;
      white-space: nowrap;
    }
  }
</style>
