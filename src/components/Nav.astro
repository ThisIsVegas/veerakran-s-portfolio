---
import { withBase, withoutBase } from '../utils/paths';

const links = [
  { href: withBase(), path: '/', label: 'Home' },
  { href: withBase('resume'), path: '/resume', label: 'Resume' },
];

const currentPath = Astro.url.pathname;
const relativePath = withoutBase(currentPath);
---

<nav aria-label="Primary">
  <ul class="nav-list">
    {links.map((link) => (
      <li>
        <a href={link.href} aria-current={relativePath === link.path ? 'page' : undefined}>
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  nav {
    display: block;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-list {
    display: flex;
    gap: clamp(0.85rem, 2.5vw, 1.5rem);
  }

  a {
    color: var(--color-muted);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    text-underline-offset: 0.3em;
  }

  a:hover,
  a[aria-current='page'] {
    color: var(--color-text);
  }

  a[aria-current='page'] {
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-decoration-thickness: 0.12rem;
  }
</style>
