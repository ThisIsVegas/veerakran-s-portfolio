---
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/resume', label: 'Resume' },
  { href: '/contact', label: 'Contact' },
];
---

<nav aria-label="Primary">
  <ul class="nav-list">
    {links.map((link) => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>

  <details class="nav-toggle">
    <summary>Menu</summary>
    <ul>
      {links.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
  </details>
</nav>

<style>
  nav {
    border-bottom: 1px solid var(--color-border);
    max-width: var(--content-width);
    margin-inline: auto;
    padding: var(--spacing-2);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-list {
    display: none;
    gap: var(--spacing-3);
  }

  summary {
    cursor: pointer;
    font-weight: 600;
    list-style: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .nav-toggle ul {
    display: flex;
    gap: var(--spacing-3);
    margin-top: var(--spacing-2);
    flex-wrap: wrap;
  }

  @media (min-width: 40rem) {
    .nav-list {
      display: flex;
    }

    .nav-toggle {
      display: none;
    }
  }
</style>
