---
import { withBase, withoutBase } from '../utils/paths';

const year = new Date().getFullYear();

const siteLinks = [
  { href: withBase(), path: '/', label: 'Home' },
  { href: withBase('projects/'), path: '/projects', label: 'Projects' },
  { href: withBase('resume'), path: '/resume', label: 'Resume' },
];

const currentPath = Astro.url.pathname;
const relativePath = withoutBase(currentPath);
const isCurrent = (path: string) =>
  path === '/projects' ? relativePath.startsWith('/projects') : relativePath === path;
---

<footer id="contact">
  <div class="footer-inner">
    <div class="footer-col">
      <p class="footer-label">Contact</p>
      <div class="contact-links">
        <a href="mailto:veerakran.s@gmail.com" aria-label="Email">
          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3.5" y="5" width="17" height="14" rx="1.5"/><path d="M4.5 6.5L12 12.5L19.5 6.5"/></svg>
        </a>
        <a href="https://linkedin.com/in/veerakran-s" rel="me" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.94 8.5H3.56V20.5H6.94V8.5Z"/><path d="M5.25 3.5C4.15 3.5 3.25 4.4 3.25 5.5C3.25 6.6 4.15 7.5 5.25 7.5C6.35 7.5 7.25 6.6 7.25 5.5C7.25 4.4 6.35 3.5 5.25 3.5Z"/><path d="M9.5 8.5H12.74V10.02H12.79C13.24 9.17 14.34 8.27 15.99 8.27C19.4 8.27 20.5 10.36 20.5 13.44V20.5H17.13V14.13C17.13 12.68 17.1 10.82 15 10.82C12.87 10.82 12.87 12.55 12.87 14.23V20.5H9.5V8.5Z"/></svg>
        </a>
      </div>
      <p class="footer-status">Open to Backend Developer opportunities</p>
      <p class="footer-location">Chonburi, Thailand</p>
    </div>

    <div class="footer-col">
      <p class="footer-label">Site</p>
      <ul class="sitemap-links">
        {siteLinks.map((link) => (
          <li>
            <a href={link.href} aria-current={isCurrent(link.path) ? 'page' : undefined}>{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer-col footer-meta">
      <p class="copyright">&copy; {year} Veerakran Sereerungruangkul</p>
      <a class="back-to-top" href="#main-content">Back to top <span aria-hidden="true">&uarr;</span></a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    scroll-margin-top: 2rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr;
    gap: 2rem;
    max-width: var(--site-width);
    margin-inline: auto;
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1.25rem, 4vw, 2rem);
  }

  .footer-label {
    margin-bottom: 0.65rem;
    color: var(--color-muted);
    font-family: var(--font-utility);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .contact-links a {
    display: grid;
    place-items: center;
    width: 2.35rem;
    height: 2.35rem;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    text-decoration: none;
  }

  .contact-links a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .contact-links svg {
    width: 1.05rem;
    height: 1.05rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .contact-links a[aria-label='LinkedIn'] svg {
    fill: currentColor;
    stroke: none;
  }

  .footer-status,
  .footer-location {
    margin-top: 0.85rem;
    color: var(--color-muted);
    font-size: var(--text-supporting);
  }

  .footer-location {
    margin-top: 0.3rem;
  }

  .sitemap-links {
    display: grid;
    gap: 0.6rem;
    list-style: none;
  }

  .sitemap-links a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .sitemap-links a:hover,
  .sitemap-links a[aria-current='page'] {
    color: var(--color-text);
  }

  .footer-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
  }

  .copyright {
    color: var(--color-muted);
    font-size: var(--text-supporting);
    text-align: right;
  }

  .back-to-top {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-muted);
    font: 600 var(--text-label) var(--font-utility);
    letter-spacing: 0.06em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .back-to-top:hover {
    color: var(--color-accent);
  }

  @media (max-width: 45rem) {
    .footer-inner {
      grid-template-columns: 1fr;
    }

    .footer-meta {
      align-items: flex-start;
    }

    .copyright {
      text-align: left;
    }
  }

  @media print {
    footer {
      display: none;
    }
  }
</style>
